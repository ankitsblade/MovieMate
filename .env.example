NVIDIA_API_KEY=your_nvidia_api_key
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

NVIDIA_EMBED_MODEL=nvidia/llama-nemotron-embed-1b-v2
NVIDIA_CHAT_MODEL=openai/gpt-oss-120b
NVIDIA_RERANK_MODEL=nvidia/llama-nemotron-rerank-1b-v2
NVIDIA_RERANK_URL=https://ai.api.nvidia.com/v1/retrieval/nvidia/llama-nemotron-rerank-1b-v2/reranking

EMBED_DIMENSIONS=384

SUPABASE_DB_URL=postgresql://user:password@host:5432/postgres

TOP_K_RETRIEVE=30
TOP_K_FINAL=6

LANGSMITH_PROJECT=moviemate-dev
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=

ENABLE_LLM_EVAL=true
EVAL_CHAT_MODEL=openai/gpt-oss-120b
EVAL_LLM_TIMEOUT_SECONDS=30

LOW_SIGNAL_RETRY_THRESHOLD=0.5
LOW_SIGNAL_MAX_RETRIES=1
